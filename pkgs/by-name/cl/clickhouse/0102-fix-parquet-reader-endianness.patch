+/// Parquet stores all multi-byte integers in little-endian byte order.
+/// This helper converts from little-endian to native byte order.
+/// On little-endian platforms it compiles to a no-op.
+template <typename T>
+requires std::is_integral_v<T>
+static inline T fromLittleEndian(T x)
+{
+    if constexpr (std::endian::native != std::endian::little)
+        return std::byteswap(x);
+    return x;
+}
